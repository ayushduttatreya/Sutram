# .env.example

# Database (all services connect via PgBouncer)
DATABASE_URL=postgresql+asyncpg://sutram:sutram@localhost:5432/sutram

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256

# Internal service auth
INTERNAL_AUTH_TOKEN=dev-internal-token-change-in-production

# OpenAI (for embeddings)
OPENAI_API_KEY=sk-...

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
